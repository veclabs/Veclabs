# Gemini API key — get from aistudio.google.com
GEMINI_API_KEY=your-key-here

# VecLabs persistence key — encrypts .veclabs/*.db files (AES-256-GCM).
# The collection is loaded from disk on each server restart using this key.
# Use any strong passphrase; changing it makes existing .db files unreadable.
VECLABS_PERSIST_KEY=change-me-before-production

# Optional: Helius RPC for better devnet performance
# HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=...
